import matplotlib.pyplot as plt
import numpy as np


def txt_to_matrix(filename):
    matrix = []
    
    # Open the file for reading
    with open(filename, 'r') as file:
        # Read each line in the file
        for line in file:
            # Strip any leading/trailing whitespace (including newline characters)
            line = line.strip()
            # Split the line into elements (by spaces or commas)
            elements = line.split()  # Change to line.split(',') if elements are comma-separated
            
            # Convert elements to appropriate data types if necessary
            # For example, if the matrix consists of numbers, you can use:
            # elements = [int(el) for el in elements]   # If the elements are integers
            # elements = [float(el) for el in elements] # If the elements are floating-point numbers
            
            # Append the row (list of elements) to the matrix
            matrix.append(elements)
    
    return matrix


