for j in range(0, len(force[:]), 102):  # Loop through the force array in blocks of 102
    # Slice the current block of force and displacement
    current_force = force[j:j+102]
    current_disp = disp[j:j+102]
    
    # Calculate stiffness for this block
    Y1 = float(max(current_force))
    Y2 = float(min(current_force))
    index1 = current_force.index(max(current_force))
    index2 = current_force.index(min(current_force))
    X1 = float(current_disp[index1])
    X2 = float(current_disp[index2])
    
    stiff = (Y2 - Y1) / (X2 - X1+0.0000000001)
    
    # Append the calculated stiffness
    stiffness.append(stiff)

    
